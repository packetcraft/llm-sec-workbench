# ──────────────────────────────────────────────────────────────────────────────
# LLM Security Workbench — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file — it is blocked by .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# Ollama host URL.
# Native run: keep localhost default.
# Docker Compose: use host.docker.internal so the container can reach Ollama on the host.
OLLAMA_HOST="http://localhost:11434"  # use this for native / non-Docker runs
# OLLAMA_HOST="http://host.docker.internal:11434"

# ── Palo Alto Networks AIRS (AI Runtime Security) — optional cloud tier ────────
# Required only for AIRS Inlet + AIRS Dual gates. All local gates run without these.
# Both gates SKIP gracefully when these are absent or left as placeholder values.
#
# AIRS_API_KEY  — your x-pan-token from Strata Cloud Manager.
#                 Obtain at: https://stratacloudmanager.paloaltonetworks.com/
#
# AIRS_PROFILE  — the AI security profile name you configured in Strata Cloud Manager.
#                 This controls which threat categories AIRS evaluates (injection,
#                 DLP, toxic content, URL cats, etc.). Must match an existing profile.
#                 Example values: "default", "strict-dlp", "my-custom-profile"
#
AIRS_API_KEY="your-x-pan-token-here"
AIRS_PROFILE="your-profile-name-here"
