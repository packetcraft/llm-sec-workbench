# ──────────────────────────────────────────────────────────────────────────────
# LLM Security Workbench — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file — it is blocked by .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# Ollama host URL.
# When running via Docker Compose, set this to the Docker bridge address so the
# container can reach the Ollama instance running on the host machine.
# When running natively (pip install), keep the localhost default.
# OLLAMA_HOST="http://host.docker.internal:11434"
OLLAMA_HOST="http://localhost:11434"
# OLLAMA_HOST="http://localhost:11434"   # use this for native / non-Docker runs

# Palo Alto Networks Prisma AIRS API Key.
# Required only for Gate 4 (AIRS-Inlet) and Gate 7 (AIRS-Dual).
# Leave blank to run without cloud scanning gates.
PANW_API_KEY="your_panw_airs_api_key_here"
